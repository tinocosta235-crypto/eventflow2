generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  website   String?
  plan      String   @default("FREE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users   UserOrganization[]
  events  Event[]
  invites OrgInvite[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  organizations UserOrganization[]
}

model UserOrganization {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   @default("MEMBER")
  createdAt      DateTime @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@unique([userId, organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Event {
  id             String    @id @default(cuid())
  organizationId String
  slug           String    @unique
  title          String
  description    String?
  coverImage     String?
  status         String    @default("DRAFT")
  eventType      String    @default("CONFERENCE")

  startDate      DateTime?
  endDate        DateTime?
  timezone       String?   @default("Europe/Rome")

  location       String?
  city           String?
  country        String?   @default("IT")
  online         Boolean   @default(false)
  onlineUrl      String?

  capacity       Int?
  currentCount   Int       @default(0)
  tags           String?
  visibility     String    @default("PUBLIC")
  website        String?

  venueSetup     String?
  venueNotes     String?

  accommodationNeeded Boolean   @default(false)
  hotelName           String?
  hotelAddress        String?
  hotelCheckIn        DateTime?
  hotelCheckOut       DateTime?
  roomBlockSize       Int?
  roomBlockDeadline   DateTime?
  accommodationNotes  String?

  travelNeeded     Boolean @default(false)
  airportTransfer  Boolean @default(false)
  shuttleService   Boolean @default(false)
  parkingAvailable Boolean @default(false)
  travelNotes      String?

  organizerName    String?
  organizerEmail   String?
  organizerPhone   String?
  secretariatNotes String?

  budgetEstimated Float?
  budgetActual    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  registrations  Registration[]
  formFields     FormField[]
  emailTemplates EmailTemplate[]
  checkIns       CheckIn[]
  kpiConfig      KpiConfig?
  kpiSnapshots   KpiSnapshot[]
  emailSendLogs  EmailSendLog[]
}

model Registration {
  id               String    @id @default(cuid())
  eventId          String
  registrationCode String    @unique
  status           String    @default("PENDING")
  firstName        String
  lastName         String
  email            String
  phone            String?
  company          String?
  jobTitle         String?
  notes            String?
  source           String    @default("web")
  paymentStatus    String    @default("FREE")
  ticketPrice      Float?
  checkedInAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  event   Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fields  RegistrationField[]
  checkIn CheckIn?
  @@unique([eventId, email])
}

model FormField {
  id          String   @id @default(cuid())
  eventId     String
  label       String
  type        String
  placeholder String?
  required    Boolean  @default(false)
  options     String?
  conditions  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  event              Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrationFields RegistrationField[]
}

model RegistrationField {
  id             String  @id @default(cuid())
  registrationId String
  fieldId        String
  value          String?
  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  field        FormField    @relation(fields: [fieldId], references: [id])
  @@unique([registrationId, fieldId])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  eventId   String?
  name      String
  subject   String
  body      String
  type      String   @default("CUSTOM")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model CheckIn {
  id             String   @id @default(cuid())
  eventId        String
  registrationId String   @unique
  checkedInAt    DateTime @default(now())
  method         String   @default("manual")
  event        Event        @relation(fields: [eventId], references: [id])
  registration Registration @relation(fields: [registrationId], references: [id])
}

model OrgInvite {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String   @default("MEMBER")
  token          String   @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@unique([organizationId, email])
}

// M5 — d*motion Score Engine

model KpiConfig {
  id        String   @id @default(cuid())
  eventId   String   @unique
  // JSON: { registration_rate: 25, confirmed_rate: 20, checkin_rate: 15, email_open_rate: 15, email_click_rate: 10, form_completion_rate: 10, waitlist_conversion: 5 }
  weights   String   @default("{}")
  // JSON array of enabled kpi keys
  enabled   String   @default("[]")
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model KpiSnapshot {
  id      String   @id @default(cuid())
  eventId String
  // JSON: { registration_rate: 0.75, confirmed_rate: 0.9, ... }
  values  String   @default("{}")
  score   Float    @default(0)
  takenAt DateTime @default(now())
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EmailSendLog {
  id             String    @id @default(cuid())
  eventId        String
  registrationId String?
  email          String
  subject        String
  templateId     String?
  status         String    @default("SENT")
  openedAt       DateTime?
  clickedAt      DateTime?
  sentAt         DateTime  @default(now())
  event          Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
