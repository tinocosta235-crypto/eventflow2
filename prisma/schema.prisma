generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  description  String?
  coverImage   String?
  status       String    @default("DRAFT")
  startDate    DateTime?
  endDate      DateTime?
  location     String?
  online       Boolean   @default(false)
  onlineUrl    String?
  capacity     Int?
  currentCount Int       @default(0)
  tags         String?
  visibility   String    @default("PUBLIC")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  registrations  Registration[]
  formFields     FormField[]
  emailTemplates EmailTemplate[]
  checkIns       CheckIn[]
  invitees       Invitee[]
}

model Registration {
  id               String    @id @default(cuid())
  eventId          String
  registrationCode String    @unique
  status           String    @default("PENDING")
  firstName        String
  lastName         String
  email            String
  phone            String?
  company          String?
  jobTitle         String?
  notes            String?
  source           String    @default("web")
  paymentStatus    String    @default("FREE")
  ticketPrice      Float?
  checkedInAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  event   Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fields  RegistrationField[]
  checkIn CheckIn?

  @@unique([eventId, email])
}

model FormField {
  id          String   @id @default(cuid())
  eventId     String
  label       String
  type        String
  placeholder String?
  required    Boolean  @default(false)
  options     String?
  conditions  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  event              Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrationFields RegistrationField[]
}

model RegistrationField {
  id             String  @id @default(cuid())
  registrationId String
  fieldId        String
  value          String?

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  field        FormField    @relation(fields: [fieldId], references: [id])

  @@unique([registrationId, fieldId])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  eventId   String?
  name      String
  subject   String
  body      String
  type      String   @default("CUSTOM")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model CheckIn {
  id             String   @id @default(cuid())
  eventId        String
  registrationId String   @unique
  checkedInAt    DateTime @default(now())
  method         String   @default("manual")

  event        Event        @relation(fields: [eventId], references: [id])
  registration Registration @relation(fields: [registrationId], references: [id])
}

// ─── LISTA INVITATI PRE-EVENTO ───────────────────────────────────────────────

model Invitee {
  id          String    @id @default(cuid())
  eventId     String
  firstName   String
  lastName    String
  email       String
  phone       String?
  company     String?
  jobTitle    String?

  // Stato risposta
  status          String  @default("PENDING")   // PENDING | CONFIRMED | DECLINED | NO_RESPONSE
  declineReason   String?
  dietary         String?   // esigenze alimentari
  accessibility   String?   // esigenze accessibilità
  companions      Int       @default(0)

  // Tracking invii
  invitesSent     Int       @default(0)
  lastInviteSentAt DateTime?
  emailOpenedAt   DateTime?
  emailClickedAt  DateTime?
  inviteToken     String    @unique @default(cuid())

  // Conversione a iscrizione
  convertedToRegistration Boolean @default(false)
  registrationId          String?

  // Fonte
  source  String  @default("MANUAL")  // MANUAL | EXCEL | FORM | CRM

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  travelPlan  TravelPlan?
  customFields InviteeCustomField[]
  inviteLogs  InviteLog[]

  @@unique([eventId, email])
}

model TravelPlan {
  id        String @id @default(cuid())
  inviteeId String @unique

  // Trasporto andata
  transportType        String?  // TRAIN | FLIGHT | CAR | BUS | OTHER
  transportNumber      String?
  departureLocation    String?
  arrivalLocation      String?
  departureTime        DateTime?
  arrivalTime          DateTime?

  // Trasporto ritorno
  returnTransportType     String?
  returnTransportNumber   String?
  returnDepartureLocation String?
  returnArrivalLocation   String?
  returnDepartureTime     DateTime?
  returnArrivalTime       DateTime?

  // Hotel
  hotelName    String?
  hotelAddress String?
  checkIn      DateTime?
  checkOut     DateTime?
  roomNumber   String?
  bookingRef   String?

  // Trasferimento sede
  transferType  String?  // SHUTTLE | TAXI | OWN_CAR | OTHER
  transferNotes String?

  // Rimborso spese
  reimbursementAmount  Float?
  reimbursementStatus  String?  // NONE | REQUESTED | APPROVED | PAID
  reimbursementNotes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invitee Invitee @relation(fields: [inviteeId], references: [id], onDelete: Cascade)
}

model InviteeCustomField {
  id        String @id @default(cuid())
  inviteeId String
  fieldName String
  fieldType String  @default("text")  // text | number | date | url | select | boolean
  value     String?

  invitee Invitee @relation(fields: [inviteeId], references: [id], onDelete: Cascade)
}

model InviteLog {
  id           String   @id @default(cuid())
  inviteeId    String
  sentAt       DateTime @default(now())
  emailSubject String?
  method       String   @default("email")  // email | manual
  notes        String?

  invitee Invitee @relation(fields: [inviteeId], references: [id], onDelete: Cascade)
}

