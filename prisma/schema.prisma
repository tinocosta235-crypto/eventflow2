generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  website   String?
  plan      String   @default("FREE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users         UserOrganization[]
  events        Event[]
  invites       OrgInvite[]
  hotels        Hotel[]
  emailTemplates OrgEmailTemplate[]
  emailSenders   OrgEmailSender[]
  integrations   OrgIntegration[]
}

model OrgEmailTemplate {
  id             String   @id @default(cuid())
  organizationId String
  type           String   // "HEADER" | "FOOTER"
  payload        String   // JSON EmailBuilderPayload (solo blocks + branding)
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@unique([organizationId, type])
}

model OrgEmailSender {
  id             String   @id @default(cuid())
  organizationId String
  displayName    String
  email          String
  domain         String
  resendDomainId String?
  status         String   @default("PENDING")
  // PENDING | VERIFIED | FAILED
  dnsRecords     String?  // JSON: Resend DNS records array
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@unique([organizationId, email])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  organizations UserOrganization[]
}

model UserOrganization {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   @default("MEMBER")
  createdAt      DateTime @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@unique([userId, organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── INTEGRATIONS ──────────────────────────────────────────
// Provider: GOOGLE | MICROSOFT | AMADEUS | BOOKING | WHATSAPP | TELEGRAM
// Status:   PENDING | CONNECTED | EXPIRED | REVOKED | ERROR
model OrgIntegration {
  id             String   @id @default(cuid())
  organizationId String
  provider       String   // GOOGLE | MICROSOFT | AMADEUS | BOOKING | WHATSAPP | TELEGRAM
  status         String   @default("PENDING")

  // OAuth tokens (AES-256-GCM encrypted JSON blob)
  encryptedTokens String?  // { access_token, refresh_token, expires_at, scope }

  // API-key based integrations
  encryptedApiKey String?

  // Scopes granted
  scopes         String?  // JSON string[]

  // GDPR consent
  consentGivenAt DateTime?
  consentGivenBy String?   // userId
  revokedAt      DateTime?
  revokedBy      String?   // userId

  // Metadata (email/name of connected account, etc.)
  meta           String?  // JSON

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
}

model Event {
  id             String    @id @default(cuid())
  organizationId String
  slug           String    @unique
  title          String
  description    String?
  coverImage     String?
  status         String    @default("DRAFT")
  eventType      String    @default("CONFERENCE")

  startDate      DateTime?
  endDate        DateTime?
  timezone       String?   @default("Europe/Rome")

  location       String?
  city           String?
  country        String?   @default("IT")
  online         Boolean   @default(false)
  onlineUrl      String?

  capacity       Int?
  currentCount   Int       @default(0)
  tags           String?
  visibility     String    @default("PUBLIC")
  website        String?

  venueSetup     String?
  venueNotes     String?

  accommodationNeeded Boolean   @default(false)
  hotelName           String?
  hotelAddress        String?
  hotelCheckIn        DateTime?
  hotelCheckOut       DateTime?
  roomBlockSize       Int?
  roomBlockDeadline   DateTime?
  accommodationNotes  String?

  travelNeeded     Boolean @default(false)
  airportTransfer  Boolean @default(false)
  shuttleService   Boolean @default(false)
  parkingAvailable Boolean @default(false)
  travelNotes      String?

  organizerName    String?
  organizerEmail   String?
  organizerPhone   String?
  secretariatNotes String?

  budgetEstimated Float?
  budgetActual    Float?

  clientName       String?
  wizardCompleted  Boolean  @default(false)

  // Paperclip integration — company per governance agenti
  paperclipCompanyId String?
  // JSON: { flow_consultant, report, email_analyst, form_audit } → agentId Paperclip
  paperclipAgentIds  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  registrations  Registration[]
  formFields     FormField[]
  emailTemplates EmailTemplate[]
  checkIns       CheckIn[]
  kpiConfig      KpiConfig?
  kpiSnapshots   KpiSnapshot[]
  emailSendLogs  EmailSendLog[]
  groups         EventGroup[]
  plugins        EventPlugin[]
  allotments     HotelAllotment[]
  travelEntries  TravelEntry[]
  travelResources TravelResource[]
  travelRoutes    TravelRoute[]
  agentProposals   AgentProposal[]
  agentActionLogs  AgentActionLog[]
  agentContextCache AgentContextCache?
  emailTrackingEvents EmailTrackingEvent[]
}

model EventGroup {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?
  color       String   @default("blue")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  event            Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations    Registration[]
  routeAssignments RouteGroupAssignment[]
}

model EventPlugin {
  id         String   @id @default(cuid())
  eventId    String
  pluginType String
  enabled    Boolean  @default(true)
  config     String   @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  @@unique([eventId, pluginType])
}

model Registration {
  id               String    @id @default(cuid())
  eventId          String
  groupId          String?
  registrationCode String    @unique
  status           String    @default("PENDING")
  firstName        String
  lastName         String
  email            String
  phone            String?
  company          String?
  jobTitle         String?
  notes            String?
  source           String    @default("web")
  paymentStatus    String    @default("FREE")
  ticketPrice      Float?
  checkedInAt      DateTime?
  unsubscribedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  event           Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  group           EventGroup?         @relation(fields: [groupId], references: [id], onDelete: SetNull)
  fields          RegistrationField[]
  checkIn         CheckIn?
  roomAssignments RoomAssignment[]
  travelEntries   TravelEntry[]
  flowNodeInstances FlowNodeInstance[]
  @@unique([eventId, email])
}

model FormField {
  id          String   @id @default(cuid())
  eventId     String
  label       String
  type        String
  placeholder String?
  required    Boolean  @default(false)
  options     String?
  conditions  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  event              Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrationFields RegistrationField[]
}

model RegistrationField {
  id             String  @id @default(cuid())
  registrationId String
  fieldId        String
  value          String?
  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  field        FormField    @relation(fields: [fieldId], references: [id])
  @@unique([registrationId, fieldId])
}

model EmailTemplate {
  id                 String   @id @default(cuid())
  eventId            String?
  name               String
  subject            String
  body               String
  type               String   @default("CUSTOM")
  isDefault          Boolean  @default(false)
  groupId            String?  // null = visible to all groups
  category           String   @default("manual")  // "pre_event" | "reminder" | "post_event" | "manual"
  includeUnsubscribe Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model CheckIn {
  id             String   @id @default(cuid())
  eventId        String
  registrationId String   @unique
  checkedInAt    DateTime @default(now())
  method         String   @default("manual")
  event        Event        @relation(fields: [eventId], references: [id])
  registration Registration @relation(fields: [registrationId], references: [id])
}

model OrgInvite {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String   @default("MEMBER")
  token          String   @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@unique([organizationId, email])
}

// Flow Node Instances & Manual Tasks
model FlowNodeInstance {
  id             String    @id @default(cuid())
  eventId        String
  nodeId         String
  registrationId String
  status         String    @default("PENDING")
  // PENDING | ACTIVE | COMPLETED | BLOCKED | SKIPPED | ERROR
  startedAt      DateTime?
  completedAt    DateTime?
  blockedReason  String?
  outputBranch   String?
  metadata       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  manualTasks    ManualActionTask[]

  @@unique([nodeId, registrationId])
  @@index([eventId, nodeId])
  @@index([registrationId])
}

model ManualActionTask {
  id             String    @id @default(cuid())
  eventId        String
  nodeInstanceId String
  registrationId String
  title          String
  description    String?
  assignedTo     String?
  dueAt          DateTime?
  priority       String    @default("MEDIUM")
  // HIGH | MEDIUM | LOW
  status         String    @default("OPEN")
  // OPEN | IN_PROGRESS | DONE
  chosenOutput   String?
  completedBy    String?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  nodeInstance   FlowNodeInstance @relation(fields: [nodeInstanceId], references: [id], onDelete: Cascade)

  @@index([eventId, status])
  @@index([registrationId])
}

// M5 — d*motion Score Engine

model KpiConfig {
  id        String   @id @default(cuid())
  eventId   String   @unique
  // JSON: { registration_rate: 25, confirmed_rate: 20, checkin_rate: 15, email_open_rate: 15, email_click_rate: 10, form_completion_rate: 10, waitlist_conversion: 5 }
  weights   String   @default("{}")
  // JSON array of enabled kpi keys
  enabled   String   @default("[]")
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model KpiSnapshot {
  id      String   @id @default(cuid())
  eventId String
  // JSON: { registration_rate: 0.75, confirmed_rate: 0.9, ... }
  values  String   @default("{}")
  score   Float    @default(0)
  takenAt DateTime @default(now())
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EmailSendLog {
  id             String    @id @default(cuid())
  eventId        String
  registrationId String?
  email          String
  subject        String
  templateId     String?
  resendId       String?   // ID returned by Resend API — used for webhook matching
  status         String    @default("SENT")
  openedAt       DateTime?
  clickedAt      DateTime?
  bouncedAt      DateTime?
  sentAt         DateTime  @default(now())
  event              Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  emailTrackingEvents EmailTrackingEvent[]
}

// M9 — Hospitality & Travel

model Hotel {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  city           String?
  stars          Int?
  phone          String?
  email          String?
  website        String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roomTypes      RoomType[]
  allotments     HotelAllotment[]
}

model RoomType {
  id          String   @id @default(cuid())
  hotelId     String
  name        String
  beds        Int      @default(1)
  price       Float?
  currency    String   @default("EUR")
  notes       String?
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  allotments  HotelAllotment[]
  assignments RoomAssignment[]
}

model HotelAllotment {
  id           String    @id @default(cuid())
  eventId      String
  hotelId      String
  roomTypeId   String
  totalRooms   Int       @default(0)
  checkIn      DateTime?
  checkOut     DateTime?
  deadline     DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  hotel        Hotel     @relation(fields: [hotelId], references: [id])
  roomType     RoomType  @relation(fields: [roomTypeId], references: [id])
  assignments  RoomAssignment[]
  routeSteps   RouteStep[]
  @@unique([eventId, roomTypeId])
}

model RoomAssignment {
  id             String    @id @default(cuid())
  allotmentId    String
  roomTypeId     String
  registrationId String
  checkIn        DateTime?
  checkOut       DateTime?
  confirmed      Boolean   @default(false)
  notes          String?
  createdAt      DateTime  @default(now())
  allotment      HotelAllotment @relation(fields: [allotmentId], references: [id], onDelete: Cascade)
  roomType       RoomType       @relation(fields: [roomTypeId], references: [id])
  registration   Registration   @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  @@unique([allotmentId, registrationId])
}

model TravelEntry {
  id             String    @id @default(cuid())
  eventId        String
  registrationId String
  direction      String    @default("INBOUND")
  type           String    @default("FLIGHT")
  carrier        String?
  flightNo       String?
  departure      String?
  arrival        String?
  departureTime  DateTime?
  arrivalTime    DateTime?
  confirmed      Boolean   @default(false)
  notes          String?
  createdAt      DateTime  @default(now())
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

// Travel Resources & Routes (Parcy-style)

model TravelResource {
  id                String    @id @default(cuid())
  eventId           String
  name              String
  travelType        String    @default("FLIGHT")
  departureLocation String
  arrivalLocation   String
  departureDate     DateTime?
  arrivalDate       DateTime?
  departureTime     String?
  arrivalTime       String?
  operator          String?
  serviceNumber     String?
  description       String?
  internalNotes     String?
  units             Int?
  internalCost      Float?
  sellingPrice      Float?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  event             Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  routeSteps        RouteStep[]
}

model TravelRoute {
  id                   String    @id @default(cuid())
  eventId              String
  name                 String
  internalNotes        String?
  startingLocation     String?
  startingDate         DateTime?
  maxExtraGuests       Int       @default(0)
  hidden               Boolean   @default(false)
  allowChangeRequests  Boolean   @default(false)
  changeRequestMessage String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  event            Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  steps            RouteStep[]
  groupAssignments RouteGroupAssignment[]
}

model RouteStep {
  id               String    @id @default(cuid())
  routeId          String
  order            Int
  stepType         String
  travelResourceId String?
  hotelAllotmentId String?
  checkIn          DateTime?
  checkOut         DateTime?
  notes            String?
  route          TravelRoute     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  travelResource TravelResource? @relation(fields: [travelResourceId], references: [id], onDelete: SetNull)
  allotment      HotelAllotment? @relation(fields: [hotelAllotmentId], references: [id], onDelete: SetNull)
}

model RouteGroupAssignment {
  id      String @id @default(cuid())
  routeId String
  groupId String
  route TravelRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  group EventGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  @@unique([routeId, groupId])
}

// Agentic Layer — Sprint 1 additions

model AgentProposal {
  id           String    @id @default(cuid())
  eventId      String
  orgId        String
  agentType    String
  // SCORE_MONITOR | EMAIL_DRAFT | REPORT | EMAIL_TRACKER | FORM_AUDIT
  actionType   String
  // EMAIL_SEND | MASTERLIST_CHANGE | REPORT_GENERATE | FLOW_ACTION | FORM_CHANGE
  title        String
  summary      String?
  payload      String    @default("{}")
  diffPayload  String?
  status       String    @default("PENDING")
  // PENDING | APPROVED | REJECTED | EXPIRED
  scheduledAt  DateTime?
  requestedBy  String
  decidedBy    String?
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actionLogs   AgentActionLog[]
  @@index([eventId, status])
  @@index([orgId, status])
  @@index([eventId, createdAt(sort: Desc)])
}

model AgentActionLog {
  id          String         @id @default(cuid())
  eventId     String
  orgId       String
  proposalId  String?
  agentType   String
  actionType  String
  executedBy  String
  payload     String         @default("{}")
  result      String?
  createdAt   DateTime       @default(now())
  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  proposal    AgentProposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  @@index([eventId, createdAt(sort: Desc)])
}

model AgentContextCache {
  id          String   @id @default(cuid())
  eventId     String   @unique
  contextJson String
  builtAt     DateTime @default(now())
  expiresAt   DateTime
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ─── AUDIT LOG ─────────────────────────────────────────────
// Append-only. Mai cancellare righe — usare retention policy su Supabase.
model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?  // null per eventi di sistema (es. login fallito pre-auth)
  actorId        String?  // userId o "system"
  action         String   // AuditAction type
  metadata       String?  // JSON
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([action, createdAt])
  @@index([actorId, createdAt])
}

model EmailTrackingEvent {
  id             String       @id @default(cuid())
  emailSendLogId String
  eventId        String
  eventType      String
  // OPEN | CLICK | BOUNCE | SPAM | UNSUBSCRIBE | DELIVERED
  occurredAt     DateTime     @default(now())
  metadata       String?
  emailSendLog   EmailSendLog @relation(fields: [emailSendLogId], references: [id], onDelete: Cascade)
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  @@index([emailSendLogId])
  @@index([eventId, eventType])
}
