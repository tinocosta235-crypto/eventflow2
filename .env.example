# ── Database ─────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (pooled)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?pgbouncer=true"
# Direct connection (for migrations)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"

# ── Auth ─────────────────────────────────────────────────────────────────────
# openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Production URL (no trailing slash)
NEXTAUTH_URL="https://app.tuodominio.it"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Da https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxx"
# Da Resend Dashboard → Domains → Add Domain → Signing Secret
RESEND_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxx"
# From address (deve usare il dominio verificato su Resend)
EMAIL_FROM="Phorma <noreply@tuodominio.it>"

# ── AI (Anthropic) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Paperclip (opzionale — orchestratore agenti) ──────────────────────────────
PAPERCLIP_URL="http://localhost:3100"
PAPERCLIP_API_KEY="pk_xxxxxxxxxxxxxxxxxxxxxxxxx"
# openssl rand -hex 32
PAPERCLIP_INTERNAL_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
PAPERCLIP_DB_PASSWORD="paperclip"
